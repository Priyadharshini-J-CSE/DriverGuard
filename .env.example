# ── Server ──────────────────────────────────────────────────
PORT=5000

# ── Database ─────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/deliverguard_ai
# Render:  mongodb+srv://<user>:<password>@cluster.mongodb.net/deliverguard_ai
MONGO_URI=mongodb+srv://priyadharshinij2024cse:<Wrlp0012>@practicemangodb.smb9f4.mongodb.net/?appName=PracticeMangoDB

# ── Auth ─────────────────────────────────────────────────────
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key

# ── Weather (Open-Meteo is free — no key needed) ─────────────
# Legacy OpenWeatherMap key (no longer used, kept for reference)
OPENWEATHER_API_KEY=your_openweather_api_key

# ── AQI (WAQI) ───────────────────────────────────────────────
# Get free token at: https://aqicn.org/data-platform/token/
WAQI_TOKEN=your_waqi_token

# ── Traffic (TomTom) ─────────────────────────────────────────
# Get free key at: https://developer.tomtom.com/
TOMTOM_API_KEY=your_tomtom_api_key

# ── Payments (Razorpay) ──────────────────────────────────────
# Get keys at: https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_SECRET=your_razorpay_secret

# ── OCR Microservice ─────────────────────────────────────────
# Run locally: cd backend/ocr_service && python app.py
OCR_SERVICE_URL=http://localhost:5001

# ── Frontend (Render) ────────────────────────────────────────
# Set this to your Render frontend static site URL
FRONTEND_URL=https://your-frontend.onrender.com
